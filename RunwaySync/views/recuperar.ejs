<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RunwaySync - Recuperar Contraseña</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{width:100%;height:100%;overflow:hidden;}
    body{background:#ffffff;}
    .page{
      position:relative;
      width:100vw;
      height:100vh;
      overflow:hidden;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    .bg-svg{
      position:absolute;
      top:0;left:0;
      width:100%;
      height:100%;
      object-fit:fill;
      z-index:1;
    }
    .card-overlay{
      position:relative;
      z-index:10;
      background:#d9d9d9;
      border-radius:22px;
      width:448px;
      padding:40px 46px 34px;
      box-shadow:0 8px 40px rgba(0,0,0,0.12);
    }
    .back-link{
      display:inline-flex;
      align-items:center;
      gap:6px;
      font-family:'Helvetica Neue',Arial,sans-serif;
      font-size:0.82rem;
      color:#004aad;
      text-decoration:none;
      margin-bottom:18px;
    }
    .back-link:hover{text-decoration:underline;}
    .back-link svg{width:14px;height:14px;stroke:#004aad;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
    .card-title{
      font-family:'Georgia',serif;
      font-size:2rem;
      font-weight:700;
      color:#141516;
      text-align:center;
      margin-bottom:10px;
      letter-spacing:0.01em;
    }
    .card-subtitle{
      font-family:'Helvetica Neue',Arial,sans-serif;
      font-size:0.85rem;
      color:#6f6f6f;
      text-align:center;
      margin-bottom:28px;
      line-height:1.5;
    }
    .input-box{
      background:#ffffff;
      border-radius:14px;
      padding:12px 18px 10px;
      margin-bottom:14px;
    }
    .input-label{
      display:block;
      font-family:'Helvetica Neue',Arial,sans-serif;
      font-size:0.88rem;
      font-weight:700;
      color:#231f20;
      margin-bottom:2px;
    }
    .input-field{
      width:100%;
      border:none;
      outline:none;
      background:transparent;
      font-family:'Helvetica Neue',Arial,sans-serif;
      font-size:0.88rem;
      color:#95a2a5;
    }
    .input-field::placeholder{color:#95a2a5;}
    .btn-main{
      display:flex;
      align-items:center;
      justify-content:center;
      width:100%;
      height:52px;
      background:#141516;
      color:#ffffff;
      font-family:'Georgia',serif;
      font-size:1.05rem;
      font-weight:700;
      text-decoration:none;
      border:none;
      cursor:pointer;
      border-radius:50px;
      letter-spacing:0.02em;
      margin:20px 0 0;
      box-shadow:0 4px 16px rgba(0,0,0,0.22);
      transition:background 0.2s, transform 0.15s;
    }
    .btn-main:hover{background:#333;transform:translateY(-1px);}
  </style>
</head>
<body>
<div class="page">
  <img class="bg-svg" src="/svg/9.svg" alt=""/>
  <div class="card-overlay">
    <a href="/login" class="back-link">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      Volver al inicio de sesión
    </a>
    <h2 class="card-title">¿Olvidaste tu contraseña?</h2>
    <p class="card-subtitle">Ingresa tu correo electrónico y te enviaremos un código de verificación.</p>

    <form action="/recuperar" method="POST">
      <div class="input-box">
        <label class="input-label" for="correo">Correo Electrónico</label>
        <input type="email" id="correo" name="correo" class="input-field" placeholder="ejemplo@runwaysync.com" required/>
      </div>
      <button type="submit" class="btn-main">Enviar Código</button>
    </form>
  </div>
</div>
</body>
</html>
