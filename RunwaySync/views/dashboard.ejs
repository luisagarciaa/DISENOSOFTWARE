<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RunwaySync - Dashboard</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{width:100%;height:100%;overflow:hidden;}
    body{background:#ebebeb;font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;color:#231f20;}

    /* ── GLOBAL LAYOUT ── */
    .app{display:flex;flex-direction:column;height:100vh;}

    /* ── TOP BAR (full width) ── */
    .topbar{
      background:#ffffff;
      height:52px;
      display:flex;align-items:center;justify-content:space-between;
      padding:0 20px 0 16px;
      border-bottom:1px solid #e0e0e0;
      flex-shrink:0;
      z-index:100;
    }
    .topbar-left{display:flex;align-items:center;gap:10px;}
    .hamburger{
      background:none;border:none;cursor:pointer;
      display:flex;flex-direction:column;gap:4px;padding:4px;
    }
    .hamburger span{display:block;width:20px;height:2px;background:#231f20;border-radius:2px;}
    .topbar-brand{
      font-family:'Georgia',serif;
      font-size:0.98rem;font-weight:400;
      letter-spacing:0.2em;
      color:#141516;
    }
    .topbar-right{display:flex;align-items:center;gap:16px;}
    .topbar-icon{
      width:32px;height:32px;border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      cursor:pointer;color:#231f20;
    }
    .topbar-icon:hover{background:#f3f4f6;}
    .topbar-icon svg{width:20px;height:20px;stroke:#231f20;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
    .topbar-icon.profile svg{fill:#231f20;stroke:none;}

    /* ── BODY ROW ── */
    .body-row{display:flex;flex:1;overflow:hidden;}

    /* ── SIDEBAR ── */
    .sidebar{
      flex:0 0 210px;
      background:#ffffff;
      display:flex;flex-direction:column;
      padding:12px 10px;
      border-right:1px solid #e0e0e0;
      gap:3px;
      overflow-y:auto;
    }
    .nav-item{
      display:flex;align-items:center;gap:11px;
      padding:10px 14px;
      border-radius:14px;
      text-decoration:none;
      color:#6f6f6f;
      font-size:0.88rem;font-weight:500;
      transition:background 0.15s,color 0.15s;
    }
    .nav-item:hover{background:#f3f4f6;color:#231f20;}
    .nav-item.active{background:#f0f0f0;color:#141516;font-weight:700;}
    .nav-icon{
      width:20px;height:20px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
    }
    .nav-icon svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.9;stroke-linecap:round;stroke-linejoin:round;}
    .nav-item.active .nav-icon svg{stroke:#141516;}

    /* ── CONTENT ── */
    .content{
      flex:1;overflow-y:auto;
      padding:18px 20px;
      display:flex;flex-direction:column;gap:12px;
    }

    /* ── WELCOME ── */
    .welcome h2{
      font-size:1.55rem;font-weight:800;
      color:#141516;font-family:'Georgia',serif;
      letter-spacing:0.01em;
    }
    .welcome p{font-size:0.75rem;color:#95a2a5;margin-top:2px;}

    /* ── STATS ROW ── */
    .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
    .stat-card{
      background:#ffffff;
      border-radius:16px;
      padding:15px 18px 13px;
      box-shadow:0 1px 4px rgba(0,0,0,0.05);
    }
    .stat-lbl{font-size:0.73rem;color:#8a9295;font-weight:600;margin-bottom:5px;letter-spacing:0.01em;}
    .stat-num{font-size:2.1rem;font-weight:800;color:#141516;line-height:1.1;}
    .stat-sub{font-size:0.7rem;margin-top:4px;font-weight:600;}
    .stat-sub.green{color:#08b864;}
    .stat-sub.pink{color:#cd1b80;}
    .stat-sub.amber{color:#b88917;}
    .stat-sub.purple{color:#7611bd;}

    /* ── MIDDLE ROW ── */
    .mid-row{display:grid;grid-template-columns:1fr 1.18fr;gap:10px;}

    /* ── CARD base ── */
    .card{
      background:#ffffff;
      border-radius:16px;
      padding:15px 18px;
      box-shadow:0 1px 4px rgba(0,0,0,0.05);
    }
    .card-title{
      font-size:0.65rem;font-weight:800;
      letter-spacing:0.1em;
      color:#8a9295;
      text-transform:uppercase;
      margin-bottom:13px;
    }

    /* ── PROJECTS ── */
    .project-row{display:flex;align-items:center;gap:9px;margin-bottom:8px;}
    .project-row:last-child{margin-bottom:0;}
    .p-avatar{
      width:36px;height:36px;border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      font-size:0.62rem;font-weight:800;flex-shrink:0;
    }
    .p-info{flex:1;min-width:0;}
    .p-name{font-size:0.76rem;font-weight:600;color:#141516;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .p-sub{font-size:0.64rem;color:#b0b0b0;margin-top:1px;}
    .p-bar-wrap{width:110px;height:5px;background:#ebebeb;border-radius:3px;overflow:hidden;flex-shrink:0;}
    .p-bar{height:100%;border-radius:3px;}
    .p-pct{font-size:0.67rem;color:#8a9295;width:26px;text-align:right;flex-shrink:0;font-weight:600;}

    /* ── CALENDAR ── */
    .cal-events{display:grid;grid-template-columns:1.1fr 1fr;gap:0;}
    .cal-side{padding-right:12px;}
    .cal-month{font-size:0.65rem;font-weight:800;letter-spacing:0.1em;color:#8a9295;text-transform:uppercase;margin-bottom:10px;}
    .cal-head-row{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:3px;}
    .cal-h{font-size:0.6rem;font-weight:700;color:#b0b0b0;text-align:center;padding:2px 0;}
    .cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
    .cal-day{
      font-size:0.67rem;color:#6f6f6f;
      text-align:center;
      border-radius:7px;cursor:pointer;line-height:1.15;
      width:100%;aspect-ratio:1;
      display:flex;align-items:center;justify-content:center;
      font-weight:500;
    }
    .cal-day:hover:not(.empty){background:#f3f4f6;}
    .cal-day.today{background:rgba(8,184,100,0.25);color:#08b864;font-weight:800;}
    .cal-day.today-b{background:#141516;color:#fff;font-weight:800;border-radius:50%;}
    .cal-day.dot-pink{background:rgba(205,27,128,0.18);color:#cd1b80;font-weight:800;}
    .cal-day.dot-yellow{background:rgba(184,137,23,0.22);color:#b88917;font-weight:800;}
    .cal-day.dot-green{background:rgba(8,184,100,0.22);color:#08b864;font-weight:800;}
    .cal-day.empty{pointer-events:none;color:transparent;}

    /* Events list */
    .events-side{border-left:1px solid #ebebeb;padding-left:12px;}
    .event-item{display:flex;gap:8px;margin-bottom:9px;align-items:flex-start;}
    .event-item:last-child{margin-bottom:0;}
    .event-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;margin-top:3px;}
    .event-title{font-size:0.72rem;font-weight:700;color:#141516;line-height:1.3;}
    .event-sub{font-size:0.62rem;color:#95a2a5;margin-top:1px;}

    /* ── BOTTOM ROW ── */
    .bot-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}

    /* ── CASTINGS ── */
    .cast-row{display:flex;align-items:center;gap:9px;margin-bottom:8px;}
    .cast-row:last-child{margin-bottom:0;}
    .cast-av{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:0.62rem;font-weight:800;flex-shrink:0;}
    .cast-info{flex:1;}
    .cast-name{font-size:0.76rem;font-weight:700;color:#141516;}
    .cast-sub{font-size:0.63rem;color:#b0b0b0;margin-top:1px;}
    .badge{padding:4px 11px;border-radius:20px;font-size:0.63rem;font-weight:700;flex-shrink:0;white-space:nowrap;}
    .badge.confirmed{background:#d1fae5;color:#065f46;}
    .badge.revision{background:#fef3c7;color:#92400e;}
    .badge.pending{background:#fce4f0;color:#9b174e;}

    /* ── MOODBOARD ── */
    .mood-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:9px;}
    .mood-cell{
      border-radius:10px;padding:9px 10px;
      font-size:0.68rem;font-weight:700;
      min-height:46px;display:flex;align-items:flex-end;
      line-height:1.2;
    }
    .mood-dir{font-size:0.72rem;font-weight:700;color:#141516;margin-top:2px;}
    .mood-ref{font-size:0.63rem;color:#95a2a5;margin-top:2px;}

    /* ── TAREAS ── */
    .task-row{display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid #f3f4f6;}
    .task-row:last-child{border-bottom:none;}
    .task-cb{
      width:15px;height:15px;border-radius:4px;
      border:2px solid #d0d0d0;flex-shrink:0;margin-top:1px;
      display:flex;align-items:center;justify-content:center;
    }
    .task-cb.done{background:#08b864;border-color:#08b864;}
    .task-cb.done::after{content:'✓';color:#fff;font-size:0.58rem;font-weight:900;}
    .task-txt{font-size:0.74rem;color:#231f20;flex:1;line-height:1.3;}
    .task-time{font-size:0.61rem;color:#b0b0b0;margin-top:2px;}

    /* ── LAST ROW ── */
    .last-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
    .team-row{display:flex;gap:18px;justify-content:center;padding:6px 0;}
    .team-member{display:flex;flex-direction:column;align-items:center;gap:4px;}
    .team-av{
      width:52px;height:52px;border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      font-size:0.78rem;font-weight:800;
      position:relative;
    }
    .online-dot{
      position:absolute;bottom:1px;right:1px;
      width:10px;height:10px;border-radius:50%;
      border:2px solid #fff;
    }
    .team-role{font-size:0.6rem;color:#95a2a5;text-align:center;}
    .activity-item{display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid #f3f4f6;}
    .activity-item:last-child{border-bottom:none;}
    .act-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;margin-top:3px;}
    .act-title{font-size:0.74rem;font-weight:600;color:#141516;line-height:1.3;}
    .act-time{font-size:0.62rem;color:#95a2a5;margin-top:1px;}
  </style>
</head>
<body>
<div class="app">

  <!-- ══ TOP BAR (ancho completo) ══ -->
  <header class="topbar">
    <div class="topbar-left">
      <button class="hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
      </button>
    </div>
    <span class="topbar-brand">RUNWAY SYNC</span>
    <div class="topbar-right">
      <!-- Ícono campana -->
      <div class="topbar-icon" title="Notificaciones">
        <svg viewBox="0 0 24 24">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
      </div>
      <!-- Ícono usuario -->
      <div class="topbar-icon profile" title="Perfil">
        <svg viewBox="0 0 24 24" fill="none" stroke="#231f20" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
      </div>
    </div>
  </header>

  <!-- ══ BODY (sidebar + content) ══ -->
  <div class="body-row">

    <!-- ── SIDEBAR ── -->
    <aside class="sidebar">
      <!-- Dashboard -->
      <a href="/dashboard" class="nav-item active">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24">
            <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
            <path d="M9 21V12h6v9"/>
          </svg>
        </span>
        Dashboard
      </a>
      <!-- Calendario -->
      <a href="#" class="nav-item">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </span>
        Calendario
      </a>
      <!-- Colecciones -->
      <a href="#" class="nav-item">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24">
            <path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/>
          </svg>
        </span>
        Colecciones
      </a>
      <!-- Eventos -->
      <a href="#" class="nav-item">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <rect x="7" y="14" width="3" height="3" rx="0.5"/>
          </svg>
        </span>
        Eventos
      </a>
      <!-- Proyectos -->
      <a href="#" class="nav-item">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </span>
        Proyectos
      </a>
      <!-- Equipo -->
      <a href="#" class="nav-item">
        <span class="nav-icon">
          <svg viewBox="0 0 24 24">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </span>
        Equipo
      </a>
    </aside>

    <!-- ── CONTENT ── -->
    <div class="content">

      <!-- WELCOME -->
      <div class="welcome">
        <h2>Buenos D&iacute;as Marietta</h2>
        <p>Lunes, 20 de abril de 2026 &middot; Semana 17</p>
      </div>

      <!-- STATS -->
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-lbl">Proyectos Activos</div>
          <div class="stat-num">7</div>
          <div class="stat-sub green">+ 2 este mes</div>
        </div>
        <div class="stat-card">
          <div class="stat-lbl">Colecciones en Proceso</div>
          <div class="stat-num">3</div>
          <div class="stat-sub pink">FW26 &middot; SS26 &middot; Resort</div>
        </div>
        <div class="stat-card">
          <div class="stat-lbl">Castings Agendados</div>
          <div class="stat-num">12</div>
          <div class="stat-sub amber">5 esta semana</div>
        </div>
        <div class="stat-card">
          <div class="stat-lbl">Pr&oacute;ximos Eventos</div>
          <div class="stat-num">4</div>
          <div class="stat-sub purple">Siguiente: 24 abr</div>
        </div>
      </div>

      <!-- PROYECTOS + CALENDARIO -->
      <div class="mid-row">

        <!-- Proyectos Estado General -->
        <div class="card">
          <div class="card-title">Proyectos &middot; Estado General</div>

          <div class="project-row">
            <div class="p-avatar" style="background:rgba(205,27,128,0.18);color:#cd1b80">SS</div>
            <div class="p-info">
              <div class="p-name">Editorial SS26 Vogue Milan</div>
              <div class="p-sub">Fotograf&iacute;a &middot; 28 abr</div>
            </div>
            <div class="p-bar-wrap"><div class="p-bar" style="width:75%;background:#cd1b80"></div></div>
            <div class="p-pct" style="color:#cd1b80">75%</div>
          </div>

          <div class="project-row">
            <div class="p-avatar" style="background:rgba(8,184,100,0.18);color:#08b864">FW</div>
            <div class="p-info">
              <div class="p-name">Editorial SS26 Vogue Milan</div>
              <div class="p-sub">Fotograf&iacute;a &middot; 28 abr</div>
            </div>
            <div class="p-bar-wrap"><div class="p-bar" style="width:40%;background:#08b864"></div></div>
            <div class="p-pct" style="color:#08b864">40%</div>
          </div>

          <div class="project-row">
            <div class="p-avatar" style="background:rgba(0,74,173,0.18);color:#004aad">RS</div>
            <div class="p-info">
              <div class="p-name">Editorial SS26 Vogue Milan</div>
              <div class="p-sub">Fotograf&iacute;a &middot; 28 abr</div>
            </div>
            <div class="p-bar-wrap"><div class="p-bar" style="width:20%;background:#004aad"></div></div>
            <div class="p-pct" style="color:#004aad">20%</div>
          </div>

          <div class="project-row">
            <div class="p-avatar" style="background:rgba(184,137,23,0.18);color:#b88917">EV</div>
            <div class="p-info">
              <div class="p-name">Editorial SS26 Vogue Milan</div>
              <div class="p-sub">Fotograf&iacute;a &middot; 28 abr</div>
            </div>
            <div class="p-bar-wrap"><div class="p-bar" style="width:50%;background:#b88917"></div></div>
            <div class="p-pct" style="color:#b88917">50%</div>
          </div>

          <div class="project-row">
            <div class="p-avatar" style="background:rgba(205,27,128,0.18);color:#cd1b80">CO</div>
            <div class="p-info">
              <div class="p-name">Editorial SS26 Vogue Milan</div>
              <div class="p-sub">Fotograf&iacute;a &middot; 28 abr</div>
            </div>
            <div class="p-bar-wrap"><div class="p-bar" style="width:10%;background:#231f20"></div></div>
            <div class="p-pct">10%</div>
          </div>
        </div>

        <!-- Calendario + Eventos -->
        <div class="card">
          <div class="cal-events">
            <div class="cal-side">
              <div class="cal-month">Abril 2026</div>
              <div class="cal-head-row">
                <div class="cal-h">L</div><div class="cal-h">M</div><div class="cal-h">M</div>
                <div class="cal-h">J</div><div class="cal-h">V</div><div class="cal-h">S</div>
                <div class="cal-h">D</div>
              </div>
              <!-- Abril 2026: empieza miércoles (2 celdas vacías) -->
              <div class="cal-grid">
                <div class="cal-day empty"></div>
                <div class="cal-day empty"></div>
                <div class="cal-day">1</div>
                <div class="cal-day">2</div>
                <div class="cal-day">3</div>
                <div class="cal-day">4</div>
                <div class="cal-day">5</div>
                <div class="cal-day">6</div>
                <div class="cal-day">7</div>
                <div class="cal-day today">8</div>
                <div class="cal-day">9</div>
                <div class="cal-day">10</div>
                <div class="cal-day">11</div>
                <div class="cal-day">12</div>
                <div class="cal-day">13</div>
                <div class="cal-day dot-pink">14</div>
                <div class="cal-day">15</div>
                <div class="cal-day">16</div>
                <div class="cal-day dot-yellow">17</div>
                <div class="cal-day today-b">18</div>
                <div class="cal-day">19</div>
                <div class="cal-day">20</div>
                <div class="cal-day dot-pink">21</div>
                <div class="cal-day">22</div>
                <div class="cal-day dot-pink">23</div>
                <div class="cal-day dot-yellow">24</div>
                <div class="cal-day">25</div>
                <div class="cal-day">26</div>
                <div class="cal-day">27</div>
                <div class="cal-day dot-green">28</div>
                <div class="cal-day">29</div>
                <div class="cal-day">30</div>
              </div>
            </div>
            <div class="events-side">
              <div class="event-item">
                <div class="event-dot" style="background:#cd1b80"></div>
                <div>
                  <div class="event-title">Casting Modelos SS26</div>
                  <div class="event-sub">23 abr &middot; 10:00 AM &middot; Estudio Norte</div>
                </div>
              </div>
              <div class="event-item">
                <div class="event-dot" style="background:#b88917"></div>
                <div>
                  <div class="event-title">Fitting Final Colecci&oacute;n</div>
                  <div class="event-sub">24 abr &middot; 2:00 PM &middot; Atelier</div>
                </div>
              </div>
              <div class="event-item">
                <div class="event-dot" style="background:#08b864"></div>
                <div>
                  <div class="event-title">Sesi&oacute;n Editorial Vogue CDMX</div>
                  <div class="event-sub">28 abr &middot; Todo el d&iacute;a &middot; Locaci&oacute;n TBD</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div><!-- /mid-row -->

      <!-- BOTTOM ROW -->
