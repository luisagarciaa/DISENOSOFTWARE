<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RunwaySync - Calendario</title>
  <style>
    /* ── RESET & BASE ── */
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{width:100%;height:100%;overflow:hidden;}
    body{background:#ebebeb;font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;color:#231f20;}

    /* ── APP LAYOUT ── */
    .app{display:flex;flex-direction:column;height:100vh;}

    /* ── TOP BAR ── */
    .topbar{background:#fff;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 20px 0 16px;border-bottom:1px solid #e0e0e0;flex-shrink:0;z-index:100;}
    .topbar-left{display:flex;align-items:center;gap:10px;}
    .hamburger{background:none;border:none;cursor:pointer;display:flex;flex-direction:column;gap:4px;padding:4px;}
    .hamburger span{display:block;width:20px;height:2px;background:#231f20;border-radius:2px;}
    .topbar-brand{font-family:'Georgia',serif;font-size:0.98rem;font-weight:400;letter-spacing:0.2em;color:#141516;}
    .topbar-right{display:flex;align-items:center;gap:16px;}
    .topbar-icon{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;}
    .topbar-icon:hover{background:#f3f4f6;}
    .topbar-icon svg{width:20px;height:20px;stroke:#231f20;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}

    /* ── BODY ROW ── */
    .body-row{display:flex;flex:1;overflow:hidden;}

    /* ── SIDEBAR ── */
    .sidebar{flex:0 0 210px;background:#fff;display:flex;flex-direction:column;padding:12px 10px;border-right:1px solid #e0e0e0;gap:3px;overflow-y:auto;}
    .nav-item{display:flex;align-items:center;gap:11px;padding:10px 14px;border-radius:14px;text-decoration:none;color:#6f6f6f;font-size:0.88rem;font-weight:500;transition:background .15s,color .15s;}
    .nav-item:hover{background:#f3f4f6;color:#231f20;}
    .nav-item.active{background:#f0f0f0;color:#141516;font-weight:700;}
    .nav-icon{width:20px;height:20px;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
    .nav-icon svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.9;stroke-linecap:round;stroke-linejoin:round;}

    /* ── CALENDAR WRAPPER ── */
    .cal-wrapper{flex:1;overflow:hidden;display:flex;flex-direction:column;}

    /* ── MONTH VIEW ── */
    .cal-page{flex:1;padding:18px 20px 12px;display:flex;flex-direction:column;gap:10px;overflow:hidden;}
    .cal-page-header{display:flex;justify-content:space-between;align-items:flex-start;flex-shrink:0;}
    .cal-title{font-family:'Georgia',serif;font-size:1.5rem;font-weight:800;color:#141516;}
    .cal-subtitle{font-size:0.74rem;color:#95a2a5;margin-top:3px;}
    .cal-controls{display:flex;align-items:center;gap:10px;}
    .cal-view-toggle{display:flex;background:#f0f0f0;border-radius:8px;padding:3px;gap:2px;}
    .cal-view-btn{padding:6px 14px;border-radius:6px;border:none;background:transparent;font-size:0.78rem;font-weight:600;cursor:pointer;color:#6f6f6f;transition:all .15s;}
    .cal-view-btn.active{background:#141516;color:#fff;}
    .cal-nav{display:flex;align-items:center;gap:6px;}
    .cal-nav-btn{background:#fff;border:1px solid #e0e0e0;border-radius:7px;width:28px;height:28px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:0.85rem;color:#6f6f6f;transition:background .12s;}
    .cal-nav-btn:hover{background:#f3f4f6;}
    .cal-month-lbl{font-size:0.86rem;font-weight:700;min-width:100px;text-align:center;color:#141516;}
    .btn-nuevo-evento{background:#141516;color:#fff;border:none;border-radius:50px;padding:9px 18px;font-size:0.8rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;letter-spacing:0.02em;transition:background .15s;}
    .btn-nuevo-evento:hover{background:#333;}

    /* ── CALENDAR CONTAINER ── */
    .cal-container{flex:1;background:#fff;border-radius:16px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 1px 4px rgba(0,0,0,0.05);min-height:0;}
    .cal-col-headers{display:grid;grid-template-columns:repeat(7,1fr);border-bottom:1px solid #e8e8e8;flex-shrink:0;}
    .cal-col-h{padding:10px 8px;font-size:0.65rem;font-weight:800;color:#8a9295;text-transform:uppercase;letter-spacing:0.08em;text-align:center;border-right:1px solid #f0f0f0;}
    .cal-col-h:last-child{border-right:none;}
    .cal-body-grid{flex:1;display:grid;grid-template-columns:repeat(7,1fr);min-height:0;}
    .cal-cell{border-right:1px solid #e8e8e8;border-bottom:1px solid #e8e8e8;padding:8px 7px;position:relative;cursor:pointer;overflow:hidden;transition:background .12s;}
    .cal-cell:nth-child(7n){border-right:none;}
    .cal-cell:hover{background:#fafafa;}
    .cal-cell.other-month{background:#f9f9f9;}
    .cal-cell.is-today-row{background:rgba(245,242,235,0.5);}
    .cal-cell.is-today-row:hover{background:rgba(245,242,235,0.8);}

    /* Day number */
    .day-num-wrap{display:inline-flex;flex-direction:column;align-items:center;margin-bottom:4px;}
    .day-num{font-size:0.76rem;color:#6f6f6f;font-weight:500;line-height:1;}
    .day-num.other{color:#c4c4c4;}
    .day-num-circle{width:25px;height:25px;background:#141516;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.72rem;font-weight:700;}
    .hoy-label{font-size:0.52rem;color:#8a9295;text-transform:uppercase;letter-spacing:0.06em;margin-top:1px;}

    /* Event pills */
    .event-pill{display:flex;align-items:center;gap:5px;padding:3px 7px;border-radius:5px;margin-bottom:3px;cursor:pointer;overflow:hidden;width:100%;}
    .event-pill:hover{filter:brightness(0.95);}
    .event-pill-title{font-size:0.64rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
    .more-pill{font-size:0.6rem;color:#8a9295;padding:1px 4px;cursor:pointer;}

    /* ── CALENDAR LEGEND ── */
    .cal-legend{display:flex;gap:18px;align-items:center;flex-shrink:0;}
    .legend-item{display:flex;align-items:center;gap:6px;font-size:0.7rem;color:#6f6f6f;}
    .legend-dot{width:10px;height:10px;border-radius:50%;}

    /* ── EVENT DETAIL VIEW ── */
    .event-detail-page{flex:1;overflow-y:auto;padding:18px 20px;}
    .ev-breadcrumb{font-size:0.74rem;color:#8a9295;margin-bottom:3px;display:flex;align-items:center;gap:5px;}
    .ev-breadcrumb a{color:#cd1b80;text-decoration:none;cursor:pointer;font-weight:600;}
    .ev-breadcrumb a:hover{text-decoration:underline;}
    .ev-sub-header{display:flex;align-items:center;gap:8px;font-size:0.74rem;color:#8a9295;margin-bottom:18px;}
    .ev-sub-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
    .event-detail-grid{display:grid;grid-template-columns:1fr 380px;gap:14px;align-items:start;}

    /* Event card (left) */
    .ev-card{background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.06);}
    .ev-card-bar{height:5px;}
    .ev-card-body{padding:24px;}
    .ev-type-label{font-size:0.62rem;font-weight:800;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:8px;}
    .ev-card-title{font-family:'Georgia',serif;font-size:1.7rem;font-weight:800;color:#141516;margin-bottom:6px;}
    .ev-card-desc{font-size:0.8rem;color:#8a9295;margin-bottom:0;line-height:1.5;}
    .ev-section{border-top:1px solid #f0f0f0;padding:14px 0;}.ev-section:last-child{padding-bottom:0;}
    .ev-section-label{font-size:0.6rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#8a9295;margin-bottom:8px;}
    .ev-section-val{font-size:0.86rem;color:#141516;font-weight:500;line-height:1.4;}
    .ev-type-badge{display:inline-block;padding:4px 14px;border-radius:20px;font-size:0.7rem;font-weight:700;}
    /* Model rows */
    .model-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
    .model-row:last-child{margin-bottom:0;}
    .model-av{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:800;flex-shrink:0;}
    .model-info{flex:1;}
    .model-name{font-size:0.76rem;font-weight:700;color:#141516;}
    .model-sub{font-size:0.62rem;color:#b0b0b0;margin-top:1px;}
    .model-badge{padding:4px 12px;border-radius:20px;font-size:0.62rem;font-weight:700;flex-shrink:0;}
    .badge-confirmed{background:#d1fae5;color:#065f46;}
    .badge-review{background:#fef3c7;color:#92400e;}
    .badge-pending{background:#fce4f0;color:#9b174e;}

    /* Right side cards */
    .ev-right{display:flex;flex-direction:column;gap:14px;}
    .ev-side-card{background:#fff;border-radius:16px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,0.06);}
    .ev-side-title{font-size:0.62rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#8a9295;margin-bottom:14px;}
    /* Agenda timeline */
    .agenda-row{display:flex;gap:12px;margin-bottom:12px;}
    .agenda-row:last-child{margin-bottom:0;}
    .agenda-time{font-size:0.66rem;color:#8a9295;width:38px;flex-shrink:0;padding-top:8px;font-weight:600;}
    .agenda-block{flex:1;padding:9px 12px;border-radius:10px;}
    .agenda-block-title{font-size:0.74rem;font-weight:700;}
    .agenda-block-sub{font-size:0.62rem;margin-top:2px;opacity:0.75;}
    /* Attendees */
    .attendees-row{display:flex;gap:14px;flex-wrap:wrap;}
    .attendee-item{display:flex;flex-direction:column;align-items:center;gap:4px;}
    .attendee-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.68rem;font-weight:800;}
    .attendee-name{font-size:0.61rem;color:#8a9295;text-align:center;}
    /* Action buttons */
    .ev-action-row{display:flex;gap:10px;}
    .btn-edit-ev{background:#141516;color:#fff;border:none;border-radius:50px;padding:10px 22px;font-size:0.8rem;font-weight:700;cursor:pointer;transition:background .15s;}
    .btn-edit-ev:hover{background:#333;}
    .btn-cancel-ev{background:transparent;color:#231f20;border:1.5px solid #d0d0d0;border-radius:50px;padding:10px 22px;font-size:0.8rem;font-weight:600;cursor:pointer;transition:background .12s;}
    .btn-cancel-ev:hover{background:#f3f4f6;}

    /* ── MODAL NUEVO EVENTO ── */
    .modal-backdrop{position:fixed;inset:0;background:rgba(20,21,22,0.45);z-index:900;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
    .modal-backdrop.open{opacity:1;pointer-events:all;}
    .modal-card{background:#fff;border-radius:20px;width:540px;max-height:88vh;overflow-y:auto;padding:30px 32px;box-shadow:0 12px 48px rgba(0,0,0,0.18);transform:translateY(14px);transition:transform .22s;}
    .modal-backdrop.open .modal-card{transform:translateY(0);}
    .modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:22px;}
    .modal-title{font-family:'Georgia',serif;font-size:1.2rem;font-weight:800;color:#141516;}
    .modal-close-btn{background:none;border:none;cursor:pointer;font-size:1.3rem;color:#8a9295;line-height:1;padding:2px 6px;border-radius:6px;}
    .modal-close-btn:hover{background:#f3f4f6;color:#141516;}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    .form-group{margin-bottom:16px;}
    .form-label{font-size:0.65rem;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;color:#8a9295;margin-bottom:6px;display:block;}
    .form-input,.form-textarea,.form-select{width:100%;padding:10px 13px;background:#f5f5f5;border:1.5px solid transparent;border-radius:10px;font-size:0.84rem;color:#231f20;outline:none;transition:border .15s;font-family:inherit;}
    .form-input:focus,.form-textarea:focus,.form-select:focus{border-color:#141516;background:#fff;}
    .form-textarea{resize:vertical;min-height:68px;}
    .time-row{display:flex;gap:8px;align-items:center;}
    .time-sep{color:#8a9295;font-size:0.85rem;}
    /* Color picker */
    .color-options{display:flex;gap:8px;flex-wrap:wrap;}
    .color-opt{display:flex;align-items:center;gap:7px;padding:7px 13px;border-radius:50px;border:2px solid transparent;cursor:pointer;font-size:0.72rem;font-weight:700;transition:border .15s,box-shadow .15s;background:#f5f5f5;}
    .color-opt:hover{box-shadow:0 0 0 2px rgba(0,0,0,0.1);}
    .color-opt.selected{border-color:#141516;background:#fff;}
    .color-opt-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0;}
    /* Attendees picker in modal */
    .att-grid{display:flex;gap:12px;flex-wrap:wrap;}
    .att-check{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;}
    .att-check input{display:none;}
    .att-av-sm{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:800;border:2px solid transparent;transition:border .15s,transform .15s;}
    .att-check:hover .att-av-sm{transform:scale(1.05);}
    .att-check input:checked~.att-av-sm{border-color:#141516;}
    .att-lbl-sm{font-size:0.6rem;color:#8a9295;}
    .form-buttons{display:flex;gap:10px;margin-top:20px;}
    .btn-submit-form{flex:1;background:#141516;color:#fff;border:none;border-radius:50px;padding:12px;font-size:0.84rem;font-weight:700;cursor:pointer;letter-spacing:0.02em;transition:background .15s;}
    .btn-submit-form:hover{background:#333;}
    .btn-cancel-form{padding:12px 20px;background:transparent;border:1.5px solid #e0e0e0;border-radius:50px;font-size:0.84rem;cursor:pointer;color:#6f6f6f;transition:background .12s;}
    .btn-cancel-form:hover{background:#f3f4f6;}

    /* ── MODAL MUY PRONTO ── */
    .modal-overlay{position:fixed;inset:0;background:rgba(20,21,22,0.45);display:flex;align-items:center;justify-content:center;z-index:999;opacity:0;pointer-events:none;transition:opacity .2s ease;}
    .modal-overlay.visible{opacity:1;pointer-events:all;}
    .modal-box{background:#fff;border-radius:20px;padding:36px 48px;text-align:center;box-shadow:0 12px 48px rgba(0,0,0,0.18);transform:translateY(10px) scale(0.97);transition:transform .22s ease,opacity .22s ease;opacity:0;}
    .modal-overlay.visible .modal-box{transform:translateY(0) scale(1);opacity:1;}
    .modal-icon{font-size:2rem;margin-bottom:10px;}
    .modal-title-mp{font-family:'Georgia',serif;font-size:1.6rem;font-weight:700;color:#141516;letter-spacing:.04em;margin-bottom:6px;}
    .modal-sub-mp{font-size:0.82rem;color:#95a2a5;}
    .modal-close{margin-top:22px;display:inline-block;padding:8px 28px;background:#141516;color:#fff;border:none;border-radius:50px;font-size:0.82rem;font-weight:700;cursor:pointer;letter-spacing:.04em;transition:background .15s;}
    .modal-close:hover{background:#333;}
  </style>
</head>
<body>
<div class="app">

  <!-- ══ TOPBAR ══ -->
  <header class="topbar">
    <div class="topbar-left">
      <button class="hamburger" aria-label="Menú"><span></span><span></span><span></span></button>
    </div>
    <span class="topbar-brand">RUNWAY SYNC</span>
    <div class="topbar-right">
      <div class="topbar-icon" title="Notificaciones">
        <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      </div>
      <div class="topbar-icon" title="Perfil">
        <svg viewBox="0 0 24 24" fill="none" stroke="#231f20" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </div>
    </div>
  </header>

  <!-- ══ BODY ══ -->
  <div class="body-row">

    <!-- ── SIDEBAR ── -->
    <aside class="sidebar">
      <a href="/dashboard" class="nav-item">
        <span class="nav-icon"><svg viewBox="0 0 24 24"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/><path d="M9 21V12h6v9"/></svg></span>
        Dashboard
      </a>
      <a href="/calendario" class="nav-item active">
        <span class="nav-icon"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
        Calendario
      </a>
      <a href="#" class="nav-item" onclick="mostrarMuyPronto(event)">
        <span class="nav-icon"><svg viewBox="0 0 24 24"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg></span>
        Colecciones
      </a>
      <a href="#" class="nav-item" onclick="mostrarMuyPronto(event)">
        <span class="nav-icon"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/><rect x="7" y="14" width="3" height="3" rx="0.5"/></svg></span>
        Eventos
      </a>
      <a href="#" class="nav-item" onclick="mostrarMuyPronto(event)">
        <span class="nav-icon"><svg viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></span>
        Proyectos
      </a>
      <a href="#" class="nav-item" onclick="mostrarMuyPronto(event)">
        <span class="nav-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
        Equipo
      </a>
    </aside>

    <!-- ── CALENDAR CONTENT (JS-rendered) ── -->
    <div class="cal-wrapper" id="calWrapper"></div>

  </div><!-- /body-row -->
</div><!-- /app -->

<!-- ══ MODAL NUEVO EVENTO ══ -->
<div class="modal-backdrop" id="modalBackdrop">
  <div class="modal-card">
    <div class="modal-header">
      <span class="modal-title">Nuevo Evento</span>
      <button class="modal-close-btn" onclick="closeNuevoEvento()">&#x2715;</button>
    </div>
    <form id="formNuevoEvento" onsubmit="handleNuevoEvento(event)">

      <div class="form-group">
        <label class="form-label">Nombre del evento</label>
        <input type="text" id="ev-nombre" class="form-input" placeholder="Ej. Casting Final SS26" required/>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Fecha</label>
          <input type="date" id="ev-fecha" class="form-input" required/>
        </div>
        <div class="form-group">
          <label class="form-label">Hora</label>
          <div class="time-row">
            <input type="time" id="ev-inicio" class="form-input" value="10:00"/>
            <span class="time-sep">—</span>
            <input type="time" id="ev-fin" class="form-input" value="18:00"/>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Asignar color</label>
        <div class="color-options" id="colorOptions">
          <div class="color-opt selected" data-type="casting" onclick="selectColor(this)">
            <span class="color-opt-dot" style="background:#cd1b80"></span>Casting
          </div>
          <div class="color-opt" data-type="editorial" onclick="selectColor(this)">
            <span class="color-opt-dot" style="background:#08b864"></span>Editorial
          </div>
          <div class="color-opt" data-type="fitting" onclick="selectColor(this)">
            <span class="color-opt-dot" style="background:#b88917"></span>Fitting
          </div>
          <div class="color-opt" data-type="important" onclick="selectColor(this)">
            <span class="color-opt-dot" style="background:#cd1b80"></span>Evento importante
          </div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Locaci&oacute;n</label>
        <input type="text" id="ev-locacion" class="form-input" placeholder="Estudio Norte · Av. Insurgentes, CDMX"/>
      </div>

      <div class="form-group">
        <label class="form-label">Modelos en casting</label>
        <input type="text" id="ev-modelos" class="form-input" placeholder="Ej. Tatiana Carreño, Lucas Medrano (separar con comas)"/>
      </div>

      <div class="form-group">
        <label class="form-label">Notas del evento</label>
        <textarea id="ev-notas" class="form-textarea" placeholder="Instrucciones, requerimientos, detalles importantes..."></textarea>
      </div>

      <div class="form-group">
