  { id:'e8', title:'Sesión todo el día', type:'editorial',  date:'2026-05-26', startTime:'08:00', endTime:'20:00', location:'Estudio Sur', description:'Sesión fotográfica de día completo para Look Book FW26', collection:'FW26', models:[], notes:'Preparar todos los looks. Confirmar equipo técnico.', attendees:['MR','JP'], agenda:[] }
];

/* ══════════════════════════════════════════
   STATE
══════════════════════════════════════════ */
const today = new Date();
let state = {
  year:  today.getFullYear(),
  month: today.getMonth(),  // 0-indexed
  view:  'month',
  selectedEvent: null,
  selectedColorType: 'casting'
};

/* ══════════════════════════════════════════
   STORAGE
══════════════════════════════════════════ */
function loadEvents() {
  try {
    const s = localStorage.getItem(STORAGE_KEY);
    if (s) return JSON.parse(s);
  } catch(e) {}
  const def = JSON.parse(JSON.stringify(DEFAULT_EVENTS));
  localStorage.setItem(STORAGE_KEY, JSON.stringify(def));
  return def;
}
function saveEvents(evts) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(evts));
}
let events = loadEvents();

/* ══════════════════════════════════════════
   HELPERS
══════════════════════════════════════════ */
const MONTH_NAMES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
const DAY_NAMES   = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
const DAY_NAMES_SHORT = ['Lunes','Martes','Miércoles','Jueves','Viernes','Sábado','Domingo'];

function getDaysInMonth(y, m) { return new Date(y, m+1, 0).getDate(); }
function getFirstDayIndex(y, m) { const d = new Date(y,m,1).getDay(); return d===0?6:d-1; } // Mon=0

function dateStr(y, m, d) { return `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`; }
function isToday(y, m, d) { return y===today.getFullYear() && m===today.getMonth() && d===today.getDate(); }
function isTodayRow(y, m, d) {
  const cellDate = new Date(y, m, d);
  const todayDate = new Date(today.getFullYear(), today.getMonth(), today.getDate());
  const diff = (cellDate - todayDate) / 86400000;
  // same ISO week
  const cellDay = new Date(y, m, d).getDay();
  const monOffset = cellDay === 0 ? -6 : 1 - cellDay;
  const monOfCell = new Date(y, m, d + monOffset);
  const monOfToday = new Date(today.getFullYear(), today.getMonth(), today.getDate() + (today.getDay()===0?-6:1-today.getDay()));
  return monOfCell.toDateString() === monOfToday.toDateString();
}

function getEventsForDate(dateString) {
  return events.filter(e => e.date === dateString);
}
function getEventsForMonth(y, m) {
  const prefix = `${y}-${String(m+1).padStart(2,'0')}`;
  return events.filter(e => e.date.startsWith(prefix));
}

function formatDisplayDate(dateStr) {
  const [y, m, d] = dateStr.split('-').map(Number);
  const date = new Date(y, m-1, d);
  return `${DAY_NAMES[date.getDay()]}, ${d} de ${MONTH_NAMES[m-1].toLowerCase()} ${y}`;
}

/* ══════════════════════════════════════════
   RENDER MONTH VIEW
══════════════════════════════════════════ */
function renderMonth() {
  const { year, month } = state;
  const evtsThisMonth = getEventsForMonth(year, month);
  const daysInMonth   = getDaysInMonth(year, month);
  const firstIdx      = getFirstDayIndex(year, month);
  const prevDays      = getDaysInMonth(year, month-1);
  const totalCells    = Math.ceil((firstIdx + daysInMonth) / 7) * 7;

  // Build cells array
  const cells = [];
  for (let i = firstIdx-1; i >= 0; i--) cells.push({ d: prevDays-i, m: month-1, y: year, other:true });
  for (let d = 1; d <= daysInMonth; d++) cells.push({ d, m: month, y: year, other:false });
  let nd = 1;
  while (cells.length < totalCells) cells.push({ d: nd++, m: month+1, y: year, other:true });

  // Grid rows
  const rows = cells.length / 7;

  let cellsHTML = cells.map(c => {
    const ds    = dateStr(c.y, c.m, c.d);
    const evts  = getEventsForDate(ds);
    const tod   = !c.other && isToday(c.y, c.m, c.d);
    const todRow = isTodayRow(c.y, c.m, c.d);
    let cls = 'cal-cell';
    if (c.other) cls += ' other-month';
    if (todRow && !c.other) cls += ' is-today-row';

    let dayNumHTML;
    if (tod) {
      dayNumHTML = `<div class="day-num-wrap"><div class="day-num-circle">${c.d}</div><div class="hoy-label">HOY</div></div>`;
    } else {
      // Color the number based on event type for the day
      let numColor = c.other ? '#c4c4c4' : '#6f6f6f';
      if (!c.other && evts.length > 0) {
        const cfg = TYPE_CONFIG[evts[0].type] || TYPE_CONFIG.casting;
        numColor = cfg.text;
      }
      dayNumHTML = `<div class="day-num-wrap"><div class="day-num" style="color:${numColor}">${c.d}</div></div>`;
    }

    let pillsHTML = '';
    const maxShow = 2;
    evts.slice(0, maxShow).forEach(ev => {
      const cfg = TYPE_CONFIG[ev.type] || TYPE_CONFIG.casting;
      pillsHTML += `<div class="event-pill" style="background:${cfg.bg}" onclick="showEventDetail('${ev.id}',event)">
        <span class="event-pill-title" style="color:${cfg.text}">${ev.title}</span>
      </div>`;
    });
    if (evts.length > maxShow) {
      pillsHTML += `<div class="more-pill">+${evts.length-maxShow} más</div>`;
    }

    return `<div class="${cls}" onclick="handleCellClick('${ds}')">${dayNumHTML}${pillsHTML}</div>`;
  }).join('');

  const html = `
  <div class="cal-page">
    <div class="cal-page-header">
      <div>
        <div class="cal-title">Calendario</div>
        <div class="cal-subtitle">${MONTH_NAMES[month]} ${year} &middot; ${evtsThisMonth.length} eventos este mes</div>
      </div>
      <div class="cal-controls">
        <div class="cal-view-toggle">
          <button class="cal-view-btn ${state.view==='month'?'active':''}" onclick="setView('month')">Mes</button>
          <button class="cal-view-btn ${state.view==='week'?'active':''}"  onclick="setView('week')">Semana</button>
          <button class="cal-view-btn ${state.view==='day'?'active':''}"   onclick="setView('day')">D&iacute;a</button>
        </div>
        <div class="cal-nav">
          <button class="cal-nav-btn" onclick="navigateMonth(-1)">&#8249;</button>
          <span class="cal-month-lbl">${MONTH_NAMES[month]} ${year}</span>
          <button class="cal-nav-btn" onclick="navigateMonth(1)">&#8250;</button>
        </div>
        <button class="btn-nuevo-evento" onclick="openNuevoEvento()">+ Nuevo evento</button>
      </div>
    </div>

    <div class="cal-container">
      <div class="cal-col-headers">
        ${DAY_NAMES_SHORT.map(d=>`<div class="cal-col-h">${d}</div>`).join('')}
      </div>
      <div class="cal-body-grid" style="grid-template-rows:repeat(${rows},1fr)">
        ${cellsHTML}
      </div>
    </div>

    <div class="cal-legend">
      <div class="legend-item"><div class="legend-dot" style="background:#fce4f0;border:2px solid #cd1b80"></div>Casting</div>
      <div class="legend-item"><div class="legend-dot" style="background:#d4f0e2;border:2px solid #08b864"></div>Editorial</div>
      <div class="legend-item"><div class="legend-dot" style="background:#fef3cd;border:2px solid #b88917"></div>Fitting</div>
      <div class="legend-item"><div class="legend-dot" style="background:#cd1b80"></div>Evento importante</div>
    </div>
  </div>`;

  document.getElementById('calWrapper').innerHTML = html;
}

/* ══════════════════════════════════════════
   RENDER EVENT DETAIL
══════════════════════════════════════════ */
function showEventDetail(evId, e) {
  if (e) e.stopPropagation();
  const ev = events.find(x => x.id === evId);
  if (!ev) return;
  state.selectedEvent = evId;
  renderEventDetail(ev);
}

function renderEventDetail(ev) {
  const cfg = TYPE_CONFIG[ev.type] || TYPE_CONFIG.casting;
  const [y, m, d] = ev.date.split('-').map(Number);
  const dayLabel = `${d} ${MONTH_NAMES[m-1].toLowerCase()}`;
  const fullDate = formatDisplayDate(ev.date);

  // Models rows
  let modelsHTML = ev.models.length === 0 ? '<p style="font-size:0.78rem;color:#8a9295">Sin modelos asignados.</p>' : ev.models.map(mod => {
    const ac = MODEL_COLORS[mod.initials] || {bg:'rgba(100,100,100,0.18)',text:'#6f6f6f'};
    const badgeCls = mod.status==='confirmed'?'badge-confirmed':mod.status==='review'?'badge-review':'badge-pending';
    const badgeTxt = mod.status==='confirmed'?'Confirmada':mod.status==='review'?'En revisi&oacute;n':'Pendiente';
    return `<div class="model-row">
      <div class="model-av" style="background:${ac.bg};color:${ac.text}">${mod.initials}</div>
      <div class="model-info">
        <div class="model-name">${mod.name}</div>
        <div class="model-sub">${mod.agency} &middot; ${mod.time}</div>
      </div>
      <span class="model-badge ${badgeCls}">${badgeTxt}</span>
    </div>`;
  }).join('');

  // Agenda
  let agendaHTML = '';
  if (ev.agenda.length > 0) {
    agendaHTML = ev.agenda.map(ag => {
      const ac = TYPE_CONFIG[ag.type] || TYPE_CONFIG.casting;
      return `<div class="agenda-row">
        <div class="agenda-time">${ag.time}</div>
        <div class="agenda-block" style="background:${ac.bg}">
          <div class="agenda-block-title" style="color:${ac.text}">${ag.title}</div>
          <div class="agenda-block-sub" style="color:${ac.text}">${ag.sub}</div>
        </div>
      </div>`;
    }).join('');
  } else {
    agendaHTML = '<p style="font-size:0.76rem;color:#8a9295">Sin agenda registrada.</p>';
  }

  // Attendees
  const attendeesHTML = ev.attendees.map(a => {
    const t = TEAM[a] || {name:a,bg:'rgba(100,100,100,0.18)',text:'#6f6f6f'};
    return `<div class="attendee-item">
      <div class="attendee-av" style="background:${t.bg};color:${t.text}">${a}</div>
      <div class="attendee-name">${t.name}</div>
    </div>`;
  }).join('');

  const html = `
  <div class="event-detail-page">
    <div class="ev-breadcrumb">
      <a onclick="backToCalendar()">Calendario</a>
      <span>›</span>
      <span>${dayLabel}</span>
      <span>›</span>
      <span style="color:#141516;font-weight:600">${ev.title}</span>
    </div>
    <div class="ev-sub-header">
      <div class="ev-sub-dot" style="background:${cfg.bar}"></div>
      ${cfg.label} &middot; ${fullDate} &middot; ${ev.startTime} AM
    </div>

    <div class="event-detail-grid">
      <!-- LEFT: Event card -->
      <div class="ev-card">
        <div class="ev-card-bar" style="background:${cfg.bar}"></div>
        <div class="ev-card-body">
          <div class="ev-type-label" style="color:${cfg.text}">${cfg.label.toUpperCase()} &middot; ${ev.collection||''}</div>
          <div class="ev-card-title">${ev.title}</div>
          <div class="ev-card-desc">${ev.description}</div>

          <div class="ev-section">
            <div class="ev-section-label">Fecha y hora</div>
            <div class="ev-section-val">${fullDate} &middot; ${ev.startTime} &ndash; ${ev.endTime}</div>
          </div>

          <div class="ev-section">
            <div class="ev-section-label">Locaci&oacute;n</div>
            <div class="ev-section-val">${ev.location || 'Por confirmar'}</div>
          </div>

          <div class="ev-section">
            <div class="ev-section-label">Tipo de evento</div>
            <div class="ev-type-badge" style="background:${cfg.bg};color:${cfg.text}">${cfg.label}</div>
          </div>

          ${ev.models.length > 0 ? `
          <div class="ev-section">
            <div class="ev-section-label">Modelos en casting</div>
            ${modelsHTML}
          </div>` : ''}

          ${ev.notes ? `
          <div class="ev-section">
            <div class="ev-section-label">Notas del evento</div>
            <div class="ev-section-val" style="font-size:0.82rem;color:#6f6f6f;line-height:1.5">${ev.notes}</div>
          </div>` : ''}
        </div>
      </div>

      <!-- RIGHT: Agenda + Attendees -->
      <div class="ev-right">
        <div class="ev-side-card">
          <div class="ev-side-title">Agenda del d&iacute;a &middot; ${d} ${MONTH_NAMES[m-1].toUpperCase()}</div>
          ${agendaHTML}
        </div>

        <div class="ev-side-card">
          <div class="ev-side-title">Asistentes al evento</div>
          <div class="attendees-row">${attendeesHTML || '<p style="font-size:0.76rem;color:#8a9295">Sin asistentes.</p>'}</div>
          <div class="ev-action-row" style="margin-top:18px">
            <button class="btn-edit-ev" onclick="openNuevoEvento()">Editar evento</button>
            <button class="btn-cancel-ev" onclick="backToCalendar()">Cancelar</button>
          </div>
        </div>
      </div>
    </div>
  </div>`;

  document.getElementById('calWrapper').innerHTML = html;
}

/* ══════════════════════════════════════════
   NAVIGATION
══════════════════════════════════════════ */
function navigateMonth(dir) {
  state.month += dir;
  if (state.month > 11) { state.month = 0;  state.year++; }
  if (state.month < 0)  { state.month = 11; state.year--; }
  state.selectedEvent = null;
  render();
}

function backToCalendar() {
  state.selectedEvent = null;
  render();
}

function handleCellClick(ds) {
  // Click on empty cell opens new event modal with pre-filled date
  openNuevoEvento(ds);
}

function setView(v) {
  state.view = v;
  render();
}

/* ══════════════════════════════════════════
   MODAL NUEVO EVENTO
══════════════════════════════════════════ */
function openNuevoEvento(preDate) {
  const modal = document.getElementById('modalBackdrop');
  // Set default date
  const dateInput = document.getElementById('ev-fecha');
  if (preDate) {
    dateInput.value = preDate;
  } else {
    dateInput.value = dateStr(state.year, state.month, today.getDate());
  }
  // Reset form
  document.getElementById('formNuevoEvento').reset();
  dateInput.value = preDate || dateStr(state.year, state.month, today.getDate());
  // Reset color selection
  state.selectedColorType = 'casting';
  document.querySelectorAll('.color-opt').forEach(o => o.classList.remove('selected'));
  document.querySelector('.color-opt[data-type="casting"]').classList.add('selected');
  modal.classList.add('open');
}

function closeNuevoEvento() {
  document.getElementById('modalBackdrop').classList.remove('open');
}

function selectColor(el) {
  document.querySelectorAll('.color-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  state.selectedColorType = el.dataset.type;
}

function handleNuevoEvento(e) {
  e.preventDefault();
  const nombre   = document.getElementById('ev-nombre').value.trim();
  const fecha    = document.getElementById('ev-fecha').value;
  const inicio   = document.getElementById('ev-inicio').value;
  const fin      = document.getElementById('ev-fin').value;
  const locacion = document.getElementById('ev-locacion').value.trim();
  const modelos  = document.getElementById('ev-modelos').value.trim();
  const notas    = document.getElementById('ev-notas').value.trim();
  const asistentes = [...document.querySelectorAll('input[name="asistentes"]:checked')].map(i=>i.value);

  if (!nombre || !fecha) return;

  const newEvent = {
    id:          'usr_' + Date.now(),
    title:       nombre,
    type:        state.selectedColorType,
    date:        fecha,
    startTime:   inicio,
    endTime:     fin,
    location:    locacion,
    description: '',
    collection:  '',
    models:      modelos ? modelos.split(',').map(m=>({initials:m.trim().substring(0,2).toUpperCase(),name:m.trim(),agency:'',time:'',status:'pending'})) : [],
    notes:       notas,
    attendees:   asistentes,
    agenda:      []
  };

  events.push(newEvent);
  saveEvents(events);
  closeNuevoEvento();
  // Navigate to the month of the new event
  const [y, m] = fecha.split('-').map(Number);
  state.year  = y;
  state.month = m - 1;
  render();
}

/* ══════════════════════════════════════════
   MAIN RENDER
══════════════════════════════════════════ */
function render() {
  if (state.selectedEvent) {
    const ev = events.find(x => x.id === state.selectedEvent);
    if (ev) { renderEventDetail(ev); return; }
  }
  if (state.view === 'month') {
    renderMonth();
  } else {
    // Semana / Día → show month with a simple notice for now
    renderMonth();
    // Could expand to week/day views in a future iteration
  }
}

/* ══════════════════════════════════════════
   MODAL MUY PRONTO (sidebar nav)
══════════════════════════════════════════ */
function mostrarMuyPronto(e) {
  e.preventDefault();
  document.getElementById('muyProntoModal').classList.add('visible');
}
function cerrarModal(e) {
  if (!e || e.target===document.getElementById('muyProntoModal') || e.target.classList.contains('modal-close')) {
    document.getElementById('muyProntoModal').classList.remove('visible');
  }
}
document.addEventListener('keydown', e => {
  if (e.key==='Escape') {
    closeNuevoEvento();
    cerrarModal({target:document.getElementById('muyProntoModal')});
  }
});

/* ══════════════════════════════════════════
   INIT
══════════════════════════════════════════ */
render();
</script>
</body>
</html>