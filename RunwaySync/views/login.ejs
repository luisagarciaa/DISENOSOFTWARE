<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RunwaySync - Iniciar Sesión</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{width:100%;height:100%;overflow:hidden;}
    body{background:#ffffff;}
    .page{position:relative;width:100vw;height:100vh;overflow:hidden;display:flex;align-items:center;justify-content:center;}
    .bg-svg{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:fill;z-index:1;}
    .card-overlay{position:relative;z-index:10;background:#d9d9d9;border-radius:22px;width:448px;padding:40px 46px 34px;box-shadow:0 8px 40px rgba(0,0,0,0.12);}
    .card-title{font-family:'Georgia',serif;font-size:2rem;font-weight:700;color:#141516;text-align:center;margin-bottom:28px;letter-spacing:0.01em;}
    .input-box{background:#ffffff;border-radius:14px;padding:12px 18px 10px;margin-bottom:14px;}
    .input-label{display:block;font-family:'Helvetica Neue',Arial,sans-serif;font-size:0.88rem;font-weight:700;color:#231f20;margin-bottom:2px;}
    .input-field{width:100%;border:none;outline:none;background:transparent;font-family:'Helvetica Neue',Arial,sans-serif;font-size:0.88rem;color:#95a2a5;}
    .input-field::placeholder{color:#95a2a5;}
    .forgot-row{text-align:right;margin-bottom:4px;margin-top:-4px;}
    .forgot-link{font-family:'Helvetica Neue',Arial,sans-serif;font-size:0.8rem;color:#004aad;text-decoration:none;}
    .forgot-link:hover{text-decoration:underline;}
    .btn-main{display:flex;align-items:center;justify-content:center;width:100%;height:52px;background:#141516;color:#ffffff;font-family:'Georgia',serif;font-size:1.05rem;font-weight:700;text-decoration:none;border:none;cursor:pointer;border-radius:50px;letter-spacing:0.02em;margin:20px 0 18px;box-shadow:0 4px 16px rgba(0,0,0,0.22);transition:background 0.2s,transform 0.15s;}
    .btn-main:hover{background:#333;transform:translateY(-1px);}
    .social-section{text-align:center;margin-bottom:16px;}
    .social-label{font-family:'Helvetica Neue',Arial,sans-serif;font-size:0.82rem;color:#6f6f6f;margin-bottom:12px;}
    .social-icons{display:flex;gap:14px;justify-content:center;align-items:center;}
    .social-icon{width:46px;height:46px;border-radius:50%;background:#231f20;display:flex;align-items:center;justify-content:center;text-decoration:none;cursor:pointer;transition:transform 0.15s;}
    .social-icon:hover{transform:scale(1.07);}
    .social-icon svg{width:22px;height:22px;fill:#ffffff;}
    .card-footer{text-align:center;font-family:'Helvetica Neue',Arial,sans-serif;font-size:0.86rem;color:#6f6f6f;}
    .card-footer a{color:#004aad;font-weight:700;text-decoration:none;}
    .card-footer a:hover{text-decoration:underline;}
  </style>
</head>
<body>
<div class="page">
  <img class="bg-svg" src="/svg/9.svg" alt=""/>
  <div class="card-overlay">
    <h2 class="card-title">Iniciar Sesión</h2>
    <form action="/login" method="POST">
      <div class="input-box">
        <label class="input-label" for="empresarial-id">ID Empresarial</label>
        <input type="text" id="empresarial-id" name="id_empresarial" class="input-field" placeholder=""/>
      </div>
      <div class="input-box">
        <label class="input-label" for="password">Contraseña</label>
        <input type="password" id="password" name="password" class="input-field" placeholder=""/>
      </div>
      <div class="forgot-row">
        <a href="/recuperar" class="forgot-link">¿Olvidaste tu contraseña?</a>
      </div>
      <button type="submit" class="btn-main">Iniciar Sesión</button>
    </form>
    <div class="social-section">
      <p class="social-label">Registrarse con</p>
      <div class="social-icons">
        <a href="#" class="social-icon">
          <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="#" class="social-icon">
          <svg viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </a>
        <a href="#" class="social-icon">
          <svg viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        </a>
      </div>
    </div>
    <p class="card-footer">¿No tienes una cuenta? <a href="/registro">Registrarse</a></p>
  </div>
</div>
</body>
</html>
